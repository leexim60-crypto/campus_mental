DB_USER=root
DB_PASSWORD=20061104
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=campus_mental
JWT_SECRET=lover

# 管理员受控自助注册：设为非空后开放 POST /api/v1/admin/register，须与前端填写的「注册密钥」一致（生产环境用强随机串）
# ADMIN_REGISTER_SECRET=

# AI：默认使用本机 Ollama（与 README 一致，无需 API Key）
# LLM_PROVIDER: ollama（推荐）| auto | deepseek
# - ollama：只用本机 Ollama
# - auto：有 DEEPSEEK_API_KEY 时优先 DeepSeek，否则 Ollama
# - deepseek：只用云端，必须配置 DEEPSEEK_API_KEY
LLM_PROVIDER=ollama

# 本机 Ollama（免费）：https://ollama.com 安装后终端执行：ollama pull qwen2.5:7b
# 务必用 127.0.0.1，不要用 localhost（部分环境会走 IPv6 导致连不上）
OLLAMA_BASE_URL=http://127.0.0.1:11434
# 须与 ollama list 一致；不要写成 qwen2.5:7（缺 b 会失败）。HTTP 502 多为 Ollama 推理失败或连错主机：
# uvicorn 在 WSL/Docker、Ollama 在 Windows 时不要用 127.0.0.1，应填宿主机 IP 或 host.docker.internal:11434。显存不够可改 qwen2.5:3b
OLLAMA_MODEL=qwen2.5:7b

# 加快 AI 响应（可选）：适当减小 max_tokens、限制 num_ctx；显存紧可换 qwen2.5:3b
# LLM_EVAL_MAX_TOKENS=900
# LLM_CHAT_MAX_TOKENS=512
# LLM_TIMEOUT_SEC=90
# OLLAMA_NUM_CTX=2048

# 云端 DeepSeek（可选；仅当 LLM_PROVIDER=auto 或 deepseek 时需要）
# DEEPSEEK_API_KEY=
